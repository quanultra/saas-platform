# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_DEFAULT_REGION=us-east-1
AWS_SECONDARY_REGION=eu-west-1

# Environment
ENVIRONMENT=dev

# CDK Configuration
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1

# Application Configuration
APP_NAME=aws-sap-c02-practice
APP_VERSION=1.0.0

# Database Configuration (for testing)
DB_MASTER_USERNAME=admin
# DB_MASTER_PASSWORD will be generated by AWS Secrets Manager

# Cost Management
MONTHLY_BUDGET_LIMIT=3000
COST_ALERT_THRESHOLD=2500

# Monitoring
ALERT_EMAIL=your-email@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Feature Flags
ENABLE_MULTI_REGION=true
ENABLE_DR_WARM_STANDBY=false
ENABLE_EKS_CLUSTER=false
ENABLE_REDSHIFT=false

# VPN Configuration (for Hybrid Connectivity)
CUSTOMER_GATEWAY_IP=203.0.113.1
ON_PREMISES_CIDR=192.168.0.0/16

# Domain Configuration
DOMAIN_NAME=example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxx

# Tags
PROJECT_TAG=aws-sap-c02-practice
OWNER_TAG=your-name
COST_CENTER_TAG=learning
